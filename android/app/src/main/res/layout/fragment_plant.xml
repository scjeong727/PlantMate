<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_plants"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/plant_detail_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_plant_detail_back"
                    android:layout_width="96dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_secondary_button"
                    android:text="뒤로"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_plant_placeholder" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_section_box"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/text_detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_detail_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="좌표"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <EditText
                            android:id="@+id/edit_detail_position_x"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:gravity="center"
                            android:hint="X"
                            android:inputType="numberDecimal|numberSigned"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint" />

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="52dp"
                            android:gravity="center"
                            android:text=","
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/edit_detail_position_y"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:gravity="center"
                            android:hint="Y"
                            android:inputType="numberDecimal|numberSigned"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/detail_content_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:id="@+id/panel_detail_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                android:background="@drawable/bg_section_box"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="온도:"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_temp_min"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최소"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="~"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_temp_max"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최대"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="습도:"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_humi_min"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최소"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="~"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_humi_max"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최대"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="조도:"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_light_min"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최소"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="~"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_light_max"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최대"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="토양습도:"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_soil_min"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최소"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="~"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_detail_soil_max"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:hint="최대"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint" />
                </LinearLayout>
            </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panel_detail_water"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                android:background="@drawable/bg_section_box"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="급수 시간"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_detail_water_duration"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:hint="초 단위"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:text="5"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/btn_detail_water_run"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_primary_button"
                    android:text="급수 실행"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panel_detail_robot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_section_box"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="로봇 선택"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinner_detail_robot_device"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_input"
                            android:paddingHorizontal="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <Button
                                android:id="@+id/btn_detail_robot_refresh"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_secondary_button"
                                android:text="새로고침"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btn_detail_robot_bind"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_primary_button"
                                android:text="연결"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <Button
                                android:id="@+id/btn_detail_robot_move"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_primary_button"
                                android:text="이동"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btn_detail_robot_stop"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_secondary_button"
                                android:text="정지"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_detail_robot_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/panel_detail_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                android:background="@drawable/bg_section_box"
                android:fillViewport="true"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_detail_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                    </ScrollView>
                </FrameLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/detail_bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_surface_card"
            app:itemActiveIndicatorStyle="@style/Widget.PlantMate.BottomNavigation.ActiveIndicator"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemTextColor="@color/bottom_nav_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_plant_detail_navigation" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
