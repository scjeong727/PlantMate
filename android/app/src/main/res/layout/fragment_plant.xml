<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_plant">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_plants"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_item"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/plant_detail_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_screen_plant"
        android:orientation="vertical"
        android:padding="@dimen/spacing_screen"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:paddingBottom="@dimen/spacing_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_plant_detail_back"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginBottom="@dimen/spacing_item"
                    android:background="@drawable/bg_plant_detail_back"
                    android:backgroundTint="@null"
                    android:minWidth="96dp"
                    android:paddingHorizontal="20dp"
                    android:text="뒤로"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="@dimen/plant_section_radius"
                    app:cardElevation="@dimen/elevation_card"
                    app:strokeColor="@color/plant_stroke"
                    app:strokeWidth="1dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/plant_hero_height"
                        android:background="@drawable/bg_plant_placeholder" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_section"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="@dimen/plant_section_radius"
                    app:cardElevation="@dimen/elevation_card"
                    app:strokeColor="@color/plant_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_section">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="식물 정보"
                            android:textAppearance="@style/TextAppearance.PlantMate.SectionLabel" />

                        <EditText
                            android:id="@+id/text_detail_name"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/plant_input_height"
                            android:layout_marginTop="@dimen/spacing_card"
                            android:background="@drawable/bg_plant_input"
                            android:gravity="center"
                            android:hint="식물 이름"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            android:textAppearance="@style/TextAppearance.PlantMate.DetailName"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint" />

                        <EditText
                            android:id="@+id/text_detail_type"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/plant_input_height"
                            android:layout_marginTop="@dimen/spacing_item"
                            android:background="@drawable/bg_plant_input"
                            android:gravity="center"
                            android:hint="식물 종류 (관엽식물, 다육식물 등)"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            android:textAppearance="@style/TextAppearance.PlantMate.DetailSubtitle"
                            android:textColor="@color/text_secondary"
                            android:textColorHint="@color/text_hint" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/spacing_section"
                            android:layout_marginBottom="@dimen/spacing_card"
                            android:background="@color/plant_stroke" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="좌표"
                            android:textAppearance="@style/TextAppearance.PlantMate.SectionTitle" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edit_detail_position_x"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/plant_input_height"
                                android:layout_weight="1"
                                android:background="@drawable/bg_plant_input"
                                android:gravity="center"
                                android:hint="X"
                                android:inputType="numberDecimal|numberSigned"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint" />

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="@dimen/plant_input_height"
                                android:gravity="center"
                                android:text=","
                                android:textColor="@color/text_secondary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/edit_detail_position_y"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/plant_input_height"
                                android:layout_weight="1"
                                android:background="@drawable/bg_plant_input"
                                android:gravity="center"
                                android:hint="Y"
                                android:inputType="numberDecimal|numberSigned"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <FrameLayout
                    android:id="@+id/detail_content_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_section">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/panel_detail_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/surface_card"
                        app:cardCornerRadius="@dimen/plant_section_radius"
                        app:cardElevation="@dimen/elevation_card"
                        app:strokeColor="@color/plant_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_section">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="환경 설정"
                                android:textAppearance="@style/TextAppearance.PlantMate.SectionTitle" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/plant_input_height"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="72dp"
                                    android:layout_height="wrap_content"
                                    android:text="온도:"
                                    android:textAppearance="@style/TextAppearance.PlantMate.FieldLabel" />

                                <EditText
                                    android:id="@+id/edit_detail_temp_min"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최소"
                                    android:inputType="numberDecimal|numberSigned"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:gravity="center"
                                    android:text="~"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:id="@+id/edit_detail_temp_max"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최대"
                                    android:inputType="numberDecimal|numberSigned"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/plant_input_height"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="72dp"
                                    android:layout_height="wrap_content"
                                    android:text="습도:"
                                    android:textAppearance="@style/TextAppearance.PlantMate.FieldLabel" />

                                <EditText
                                    android:id="@+id/edit_detail_humi_min"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최소"
                                    android:inputType="numberDecimal|numberSigned"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:gravity="center"
                                    android:text="~"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:id="@+id/edit_detail_humi_max"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최대"
                                    android:inputType="numberDecimal|numberSigned"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/plant_input_height"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="72dp"
                                    android:layout_height="wrap_content"
                                    android:text="조도:"
                                    android:textAppearance="@style/TextAppearance.PlantMate.FieldLabel" />

                                <EditText
                                    android:id="@+id/edit_detail_light_min"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최소"
                                    android:inputType="number"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:gravity="center"
                                    android:text="~"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:id="@+id/edit_detail_light_max"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최대"
                                    android:inputType="number"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/plant_input_height"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="72dp"
                                    android:layout_height="wrap_content"
                                    android:text="토양습도:"
                                    android:textAppearance="@style/TextAppearance.PlantMate.FieldLabel" />

                                <EditText
                                    android:id="@+id/edit_detail_soil_min"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최소"
                                    android:inputType="number"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:gravity="center"
                                    android:text="~"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:id="@+id/edit_detail_soil_max"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="최대"
                                    android:inputType="number"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/panel_detail_water"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/surface_card"
                        app:cardCornerRadius="@dimen/plant_section_radius"
                        app:cardElevation="@dimen/elevation_card"
                        app:strokeColor="@color/plant_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_section">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="급수 시간"
                                android:textAppearance="@style/TextAppearance.PlantMate.SectionTitle" />

                            <EditText
                                android:id="@+id/edit_detail_water_duration"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/plant_input_height"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:background="@drawable/bg_plant_input"
                                android:gravity="center_vertical"
                                android:hint="초 단위"
                                android:inputType="number"
                                android:paddingHorizontal="16dp"
                                android:text="5"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint" />

                            <Button
                                android:id="@+id/btn_detail_water_run"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/plant_input_height"
                                android:layout_marginTop="@dimen/spacing_section"
                                android:background="@drawable/bg_plant_primary_button"
                                android:text="급수 실행"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/panel_detail_robot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/surface_card"
                        app:cardCornerRadius="@dimen/plant_section_radius"
                        app:cardElevation="@dimen/elevation_card"
                        app:strokeColor="@color/plant_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_section">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="로봇 선택"
                                android:textAppearance="@style/TextAppearance.PlantMate.SectionTitle" />

                            <Spinner
                                android:id="@+id/spinner_detail_robot_device"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/plant_input_height"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:background="@drawable/bg_plant_input"
                                android:paddingHorizontal="12dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btn_detail_robot_refresh"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_marginEnd="@dimen/spacing_item"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_primary_button"
                                    android:text="새로고침"
                                    android:textAllCaps="false"
                                    android:textColor="@color/white"
                                    android:textStyle="bold" />

                                <Button
                                    android:id="@+id/btn_detail_robot_bind"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_marginStart="@dimen/spacing_item"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_primary_button"
                                    android:text="연결"
                                    android:textAllCaps="false"
                                    android:textColor="@color/white"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_section"
                                android:orientation="horizontal">

                                <EditText
                                    android:id="@+id/edit_detail_robot_linear"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_marginEnd="@dimen/spacing_item"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="linear"
                                    android:inputType="numberDecimal|numberSigned"
                                    android:text="0.200"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />

                                <EditText
                                    android:id="@+id/edit_detail_robot_angular"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_marginStart="@dimen/spacing_item"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_input"
                                    android:gravity="center"
                                    android:hint="angular"
                                    android:inputType="numberDecimal|numberSigned"
                                    android:text="0.000"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btn_detail_robot_move"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_marginEnd="@dimen/spacing_item"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_primary_button"
                                    android:text="이동"
                                    android:textAllCaps="false"
                                    android:textColor="@color/white"
                                    android:textStyle="bold" />

                                <Button
                                    android:id="@+id/btn_detail_robot_stop"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/plant_input_height"
                                    android:layout_marginStart="@dimen/spacing_item"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_plant_primary_button"
                                    android:text="정지"
                                    android:textAllCaps="false"
                                    android:textColor="@color/white"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/text_detail_robot_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_card"
                                android:textAppearance="@style/TextAppearance.PlantMate.DetailSubtitle" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/panel_detail_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/surface_card"
                        app:cardCornerRadius="@dimen/plant_section_radius"
                        app:cardElevation="@dimen/elevation_card"
                        app:strokeColor="@color/plant_stroke"
                        app:strokeWidth="1dp">

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fillViewport="true"
                            android:padding="@dimen/spacing_section"
                            android:scrollbars="vertical">

                            <TextView
                                android:id="@+id/text_detail_log"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:lineSpacingExtra="4dp"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />
                        </ScrollView>
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/detail_bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_nav_bar"
            android:elevation="@dimen/plant_bottom_nav_elevation"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm"
            app:itemActiveIndicatorStyle="@style/Widget.PlantMate.BottomNavigation.ActiveIndicator"
            app:itemIconSize="26dp"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemPaddingTop="2dp"
            app:itemPaddingBottom="2dp"
            app:itemTextAppearanceActive="@style/TextAppearance.PlantMate.BottomNav.Active"
            app:itemTextAppearanceInactive="@style/TextAppearance.PlantMate.BottomNav.Inactive"
            app:itemTextColor="@color/bottom_nav_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_plant_detail_navigation" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
