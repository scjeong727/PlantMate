<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.PlantMate" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/plant_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/plant_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_top</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background_bottom</item>
    </style>

    <style name="Theme.PlantMate" parent="Base.Theme.PlantMate" />

    <style name="Widget.PlantMate.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/mint_surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
    </style>

    <style name="TextAppearance.PlantMate.BottomNav.Active" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/plant_primary</item>
    </style>

    <style name="TextAppearance.PlantMate.BottomNav.Inactive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/navy_secondary</item>
    </style>
</resources>
