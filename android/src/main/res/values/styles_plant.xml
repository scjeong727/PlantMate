<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text hierarchy -->
    <style name="TextAppearance.PlantMate.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/navy_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PlantMate.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/navy_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PlantMate.SectionLabel" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/navy_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PlantMate.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/navy_primary</item>
    </style>

    <style name="TextAppearance.PlantMate.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/navy_primary</item>
    </style>

    <style name="TextAppearance.PlantMate.DetailName" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/navy_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PlantMate.DetailSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/navy_secondary</item>
    </style>

    <style name="TextAppearance.PlantMate.FieldLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/navy_secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PlantMate.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_caption</item>
    </style>

    <style name="TextAppearance.PlantMate.BrandCaption" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/navy_secondary</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Components -->
    <style name="Widget.PlantMate.Card.Section" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/plant_section_radius</item>
        <item name="cardElevation">@dimen/elevation_card_low</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/plant_stroke</item>
    </style>

    <style name="Widget.PlantMate.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.PlantMate.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_secondary_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/navy_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.PlantMate.Input" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:minHeight">@dimen/input_height</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>
</resources>
